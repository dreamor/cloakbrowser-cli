# CloakBrowser CLI — Environment Variables
# Copy this file to .env and fill in your values, or export them in your shell.

# ─── State Directory ───────────────────────────────────────────
# Override the ~/.cloak/ state directory (daemon socket, aliases, etc.)
# CLOAK_CLI_HOME=/path/to/custom/cloak

# ─── Daemon Socket ─────────────────────────────────────────────
# Override the daemon Unix socket path (default: <CLOAK_CLI_HOME>/daemon.sock)
# CLOAK_CLI_SOCK=/tmp/cloak-daemon.sock

# ─── Batch Limits ──────────────────────────────────────────────
# Max stdin bytes for `cloak batch` (default: 1000000 / 1 MB)
# CLOAK_BATCH_MAX_BYTES=1000000

# Max stdin lines for `cloak batch` (default: 200)
# CLOAK_BATCH_MAX_LINES=200

# ─── Binary & Python ───────────────────────────────────────────
# Python interpreter for `cloak serve` (CDP server gateway)
# PYTHON=python3